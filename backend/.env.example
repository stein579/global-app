# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# --- Gemini API (free tier) ---
GEMINI_API_KEY=your-gemini-api-key
# "gemini-flash-latest" is Google's alias that always points at the current
# recommended free-tier flash model. Pin to a dated model (e.g. gemini-2.5-flash)
# only if you need reproducible behavior across model upgrades.
GEMINI_MODEL=gemini-flash-latest

# --- App ---
APP_ENV=development
CORS_ORIGINS=*
